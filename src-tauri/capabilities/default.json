{
  "identifier": "default",
  "description": "Default capabilities for Desktop Clippy",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-ignore-cursor-events",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "shell:default"
  ]
}
